# 8 台集群共用变量模板。复制为各机 ops/multi-node/.env 后按角色填写 HOST_IP 与 Secret。
# Secret：openssl rand -base64 48（勿提交 Git）
# 验证可 source：set -a && source .env.cluster.example && set +a

# —— 本机（按角色改为对应私网 IP）——
# Edge-A=172.17.178.190  Edge-B=172.17.178.191
# App-A=172.17.178.189   App-B=172.17.178.197   App-C=172.17.178.192
# Middleware=172.17.178.193  Data-Sub=172.17.178.194  Data-Main=172.17.178.195
HOST_IP=172.17.178.195
SPRING_CLOUD_INETUTILS_PREFERRED_NETWORKS=172.17

# —— 集群固定地址（VPC 172.17.176.0/20）——
MW_HOST=172.17.178.193
NACOS_HOST=172.17.178.193
ES_HOST=172.17.178.193
RABBITMQ_HOST=172.17.178.193
MYSQL_HOST=172.17.178.195
MYSQL_PRIMARY_HOST=172.17.178.195
REDIS_HOST=172.17.178.195
REDIS_PRIMARY_HOST=172.17.178.195
GATEWAY_UPSTREAM=http://172.17.178.198:8080

# —— 端口 ——
MYSQL_PORT=3306
REDIS_PORT=6379
REDIS_SENTINEL_PORT=26379
ES_PORT=9200
RABBITMQ_PORT=5672
NACOS_PORT=8848

# —— 数据目录（Data-Main / Data-Sub 建议挂数据盘到 /data）——
DATA_MYSQL_DIR=/data/mysql
DATA_REDIS_DIR=/data/redis
PRODUCT_IMAGE_HOST_DIR=/data/product-images

# —— Secrets（留空，部署时填写）——
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
MYSQL_REPLICATION_USER=repl
MYSQL_REPLICATION_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_USERNAME=campus
RABBITMQ_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION_MINUTES=120
INTERNAL_API_TOKEN=
AI_CONFIG_ENCRYPTION_KEY=

# EDGE / Web（campus-web 仅绑定 127.0.0.1:8080，由 Caddy 反代）
CORS_ALLOWED_ORIGINS=https://summer.huangzixuan.asia
TRUSTED_PROXY_CIDR=127.0.0.1/32
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8080
PUBLIC_BASE_URL=https://summer.huangzixuan.asia
DOMAIN=summer.huangzixuan.asia

# AI / 邮件
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_SUPPORTS_VISION=true
AI_TIMEOUT_SECONDS=60
RESEND_API_KEY=
RESEND_FROM="Campus Market <onboarding@resend.dev>"

# JVM
JAVA_OPTS_GATEWAY="-Xms256m -Xmx256m"
JAVA_OPTS_USER="-Xms256m -Xmx256m"
JAVA_OPTS_PRODUCT="-Xms512m -Xmx512m"
JAVA_OPTS_ORDER="-Xms256m -Xmx256m"
