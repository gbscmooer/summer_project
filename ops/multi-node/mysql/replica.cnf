[mysqld]
server-id=2
gtid_mode=ON
enforce_gtid_consistency=ON
log_bin=mysql-bin
binlog_format=ROW
binlog_expire_logs_seconds=604800
relay_log=relay-bin
relay_log_recovery=ON
# Leave replica auto-start enabled: after CHANGE REPLICATION SOURCE the channel is
# persisted and must resume across container restarts.
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
default-authentication-plugin=mysql_native_password
innodb_buffer_pool_size=2G
# 注意：read_only / super_read_only 不要放这里。
# 官方入口在初始化阶段会改 root 密码；conf.d 里开 super_read_only 会导致密码设置失败、root 变空。
# 只读由 data-replica compose entrypoint 在已初始化 datadir 且存在
# /var/lib/mysql/.campus-super-read-only 标记时启用（见 enable-mysql-readonly.sh / promote-mysql.sh）。
