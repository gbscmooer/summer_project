# 复制为各机 ops/multi-node/.env 后填写。Secret 用 openssl rand -base64 48 生成，勿提交 Git。

# —— 网络（必填）——
# MW 机器的私网 IP 或 hosts 名（mysql.campus.internal）
MW_HOST=10.0.1.11
# 本机 ECS 私网 IP（写入 Nacos 的服务地址，禁止填 127.0.0.1）
HOST_IP=10.0.1.12
# VPC 网段前缀，辅助 Spring 选网卡（可与 HOST_IP 二选一强化）
SPRING_CLOUD_INETUTILS_PREFERRED_NETWORKS=10.0

# —— 中间件端口（默认即可）——
MYSQL_PORT=3306
REDIS_PORT=6379
ES_PORT=9200
RABBITMQ_PORT=5672
NACOS_PORT=8848

# —— Secrets（全部角色都可能用到的放前面；按机裁剪）——
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_USERNAME=campus
RABBITMQ_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION_MINUTES=120
INTERNAL_API_TOKEN=
AI_CONFIG_ENCRYPTION_KEY=

# EDGE / Web
CORS_ALLOWED_ORIGINS=http://10.0.1.12:8080,http://127.0.0.1:8080
TRUSTED_PROXY_CIDR=10.0.0.0/8
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=8080
PUBLIC_BASE_URL=http://10.0.1.12:8080

# AI / 邮件（product / user）
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_SUPPORTS_VISION=true
AI_TIMEOUT_SECONDS=60
RESEND_API_KEY=
RESEND_FROM=Campus Market <onboarding@resend.dev>

# JVM
JAVA_OPTS_GATEWAY=-Xms256m -Xmx256m
JAVA_OPTS_USER=-Xms256m -Xmx256m
JAVA_OPTS_PRODUCT=-Xms512m -Xmx512m
JAVA_OPTS_ORDER=-Xms256m -Xmx256m
