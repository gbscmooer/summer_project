# 边缘 TLS：公网 SLB → 本机 :80/:443 → Caddy → campus-web:8080（edge-net）
# /api/* 由 web 内 nginx 按 GATEWAY_UPSTREAM 反代到内网 CLB（保留限流）
#
# 证书：DNS 指到公网 SLB 且安全组放行 80/443 后，Caddy 自动申请 Let's Encrypt。
# 双 Edge 初始化见 README §公网 Caddy 证书。

{$DOMAIN:summer.huangzixuan.asia} {
	encode zstd gzip

	reverse_proxy campus-web:8080 {
		header_up X-Real-IP {remote_host}
	}
}

# 无 Host / IP 直访问与 ACME http-01
:80 {
	reverse_proxy campus-web:8080 {
		header_up X-Real-IP {remote_host}
	}
}
