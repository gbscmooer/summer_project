# Required deployment secrets. Generate independent random values, for example:
# openssl rand -base64 48
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION_MINUTES=120
INTERNAL_API_TOKEN=
AI_CONFIG_ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=https://your-domain.example
# HTTPS 反向代理/LB 的源 CIDR，只信任实际代理网段，禁止填写 0.0.0.0/0
TRUSTED_PROXY_CIDR=
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8080

# OpenAI-compatible API（环境变量兜底；管理员也可在「设置」页热更新）
# 示例 A：OpenAI 视觉模型
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_API_KEY=
AI_SUPPORTS_VISION=true
AI_TIMEOUT_SECONDS=60
AI_DAILY_USER_LIMIT=100
AI_GLOBAL_CONCURRENCY=8

# 示例 B：DeepSeek 文本模型（不支持图片识别时请关闭 vision）
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-v4-flash
# AI_API_KEY=
# AI_SUPPORTS_VISION=false
